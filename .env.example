# Required: server-side Anthropic API key (vibe expansion + outfit explanations).
ANTHROPIC_API_KEY=

# Optional, local dev only: absolute path to a Claude Code CLI binary. When
# ANTHROPIC_API_KEY is unset in development, LLM calls fall back to headless
# `claude -p` through your existing Claude Code login. Never used in production.
# CLAUDE_CLI=/usr/local/bin/claude
